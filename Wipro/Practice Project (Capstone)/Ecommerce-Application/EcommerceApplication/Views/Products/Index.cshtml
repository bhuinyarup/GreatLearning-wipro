@model IEnumerable<EcommerceApplication.Models.Product>

@{
    ViewData["Title"] = "Products";
}

<div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-2 mb-3">
    <div>
        <h2 class="mb-1">🛍️ Products</h2>
        <div class="text-muted">Browse items and add them to your cart</div>
    </div>

    <div class="d-flex gap-2">
        <a class="btn btn-outline-primary" asp-controller="Cart" asp-action="Index">
            <i class="bi bi-cart3 me-1"></i> View Cart
        </a>
    </div>
</div>

@if (Model == null || !Model.Any())
{
    <div class="alert alert-info">
        No products found. Add products from the Admin panel.
        <div class="mt-2">
            <a class="btn btn-sm btn-primary" asp-area="Admin" asp-controller="Products" asp-action="Index">
                Go to Admin Products
            </a>
        </div>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var p in Model)
        {
            <div class="col-12 col-sm-6 col-lg-4">
                <div class="card h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start gap-2">
                            <div>
                                <div class="fw-bold fs-5">@p.Name</div>
                                <div class="text-muted small">
                                    @(p.Category != null ? p.Category.Name : "Uncategorized")
                                </div>
                            </div>
                            <span class="badge text-bg-success fs-6">₹ @p.Price</span>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(p.Description))
                        {
                            <p class="mt-3 mb-0 text-muted">@p.Description</p>
                        }
                    </div>

                    <div class="card-footer bg-white border-0 pt-0 pb-3 px-3">
                        <form asp-controller="Cart" asp-action="Add" method="post" class="d-flex align-items-center gap-2">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="productId" value="@p.Id" />
                            <input type="number" name="qty" value="1" min="1" class="form-control" style="max-width:110px;" />
                            <button class="btn btn-primary flex-grow-1">
                                <i class="bi bi-bag-plus me-1"></i> Add to Cart
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
}