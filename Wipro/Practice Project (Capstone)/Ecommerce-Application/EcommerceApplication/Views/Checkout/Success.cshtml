@{
    ViewData["Title"] = "Order Success";
    var orderNo = (string)ViewBag.OrderNumber;
}

<div class="card shadow-sm">
    <div class="card-body text-center py-5">
        <div class="display-6 mb-2">✅ Payment Successful</div>
        <div class="text-muted mb-3">Your order has been placed.</div>

        <div class="badge text-bg-success fs-5 px-3 py-2">
            Order ID: @orderNo
        </div>

        <div class="mt-4 d-flex justify-content-center gap-2">
            <a class="btn btn-primary" asp-controller="Products" asp-action="Index">
                Continue Shopping
            </a>
            <a class="btn btn-outline-secondary" asp-area="Admin" asp-controller="Orders" asp-action="Index">
                Admin: View Orders
            </a>
        </div>
    </div>
</div>