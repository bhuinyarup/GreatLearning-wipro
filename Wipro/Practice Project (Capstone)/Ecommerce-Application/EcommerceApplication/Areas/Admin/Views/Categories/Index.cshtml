@model IEnumerable<EcommerceApplication.Models.Category>
@{
    ViewData["Title"] = "Categories";
}

<div class="row g-3">
    <div class="col-12">
        <div class="card card-soft">
            <div class="card-body">
                <div class="d-flex flex-wrap gap-2 align-items-center justify-content-between">
                    <div>
                        <h4 class="mb-1">Categories</h4>
                        <div class="text-muted small">Create, edit and manage product categories.</div>
                    </div>

                    <div class="d-flex gap-2">
                        <div class="input-group">
                            <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
                            <input id="searchBox" class="form-control" placeholder="Search categories..." />
                        </div>

                        <a class="btn btn-primary btn-soft"
                           asp-area="Admin"
                           asp-controller="Categories"
                           asp-action="Create">
                            <i class="bi bi-plus-lg me-1"></i> Create
                        </a>
                    </div>
                </div>

                <hr />

                <div class="table-responsive table-soft">
                    <table class="table table-hover align-middle mb-0" id="catTable">
                        <thead class="table-light">
                        <tr>
                            <th style="width:90px;">Id</th>
                            <th>Name</th>
                            <th>Description</th>
                            <th class="text-end" style="width:220px;">Actions</th>
                        </tr>
                        </thead>
                        <tbody>
                        @foreach (var c in Model)
                        {
                            <tr>
                                <td class="text-muted">@c.Id</td>
                                <td class="fw-semibold">@c.Name</td>
                                <td class="text-muted">@c.Description</td>
                                <td class="text-end">
                                    <a class="btn btn-outline-secondary btn-sm btn-soft"
                                       asp-area="Admin" asp-controller="Categories" asp-action="Edit" asp-route-id="@c.Id">
                                        <i class="bi bi-pencil"></i> Edit
                                    </a>

                                    <a class="btn btn-outline-danger btn-sm btn-soft ms-1"
                                       asp-area="Admin" asp-controller="Categories" asp-action="Delete" asp-route-id="@c.Id">
                                        <i class="bi bi-trash"></i> Delete
                                    </a>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>

                @if (!Model.Any())
                {
                    <div class="text-center py-5 text-muted">
                        <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                        No categories yet. Click <b>Create</b> to add your first one.
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts{
<script>
  const searchBox = document.getElementById('searchBox');
  const table = document.getElementById('catTable');
  searchBox?.addEventListener('input', () => {
    const q = searchBox.value.toLowerCase().trim();
    const rows = table.querySelectorAll('tbody tr');
    rows.forEach(r => {
      const text = r.innerText.toLowerCase();
      r.style.display = text.includes(q) ? '' : 'none';
    });
  });
</script>
}