@model EcommerceApplication.Models.Product
@{
    ViewData["Title"] = "Delete Product";
}

<h2>Delete Product</h2>

<p>Are you sure you want to delete: <b>@Model.Name</b>?</p>

<form asp-area="Admin" asp-controller="Products" asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit">Yes, Delete</button>
    <a asp-area="Admin" asp-controller="Products" asp-action="Index">Cancel</a>
</form>