@model IEnumerable<EcommerceApplication.Models.Product>
@{
    ViewData["Title"] = "Products";
}

<h2>Products</h2>

<p>
    <a asp-area="Admin" asp-controller="Products" asp-action="Create">Create New</a>
</p>

<table border="1" cellpadding="8">
    <thead>
        <tr>
            <th>Id</th>
            <th>Name</th>
            <th>Category</th>
            <th>Price</th>
            <th style="width:220px;">Actions</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var p in Model)
    {
        <tr>
            <td>@p.Id</td>
            <td>@p.Name</td>
            <td>@(p.Category?.Name)</td>
            <td>@p.Price</td>
            <td>
                <a asp-area="Admin" asp-controller="Products" asp-action="Edit" asp-route-id="@p.Id">Edit</a> |
                <a asp-area="Admin" asp-controller="Products" asp-action="Delete" asp-route-id="@p.Id">Delete</a>
            </td>
        </tr>
    }
    </tbody>
</table>